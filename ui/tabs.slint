import { Theme } from "theme.slint";
import { IconButton } from "widgets.slint";

export struct TabInfo {
    id: string,
    title: string,
    kind: string,   // "welcome" | "terminal"
    connected: bool,
}

// --- SingleTab -------------------------------------------------------------
component SingleTab inherits Rectangle {
    in property <TabInfo> info;
    in property <bool> active;
    callback selected();
    callback closed();
    callback right-clicked();  // 右键点击

    height: 30px;
    min-width: 100px;          // 缩短：原 120px，短名称（如 "pve"）时更紧凑
    max-width: 160px;          // 新增：防止长名称把 tab 撑得过宽
    horizontal-stretch: 0;    // 新增：不参与 TabBar 的等分拉伸，保持自然宽度
    border-radius: Theme.radius-sm;
    background: active ? Theme.bg-panel
        : (touch.has-hover ? Theme.bg-hover : transparent);
    animate background { duration: 120ms; }

    // Declared FIRST so the HorizontalLayout's children (close button) are at
    // a higher z-order and receive their own click events.
    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.selected(); }
        pointer-event(event) => {
            if event.button == PointerEventButton.right && event.kind == PointerEventKind.up {
                root.right-clicked();
            }
        }
    }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 6px;
        spacing: 8px;
        alignment: start;

        // Status indicator
        Rectangle {
            width: 8px; height: 8px;
            y: (parent.height - self.height) / 2;
            border-radius: 4px;
            background: info.kind == "welcome" ? Theme.text-muted
                : (info.connected ? Theme.success : Theme.warning);
        }

        Text {
            text: info.title;
            color: active ? Theme.text-primary : Theme.text-secondary;
            font-size: Theme.fs-sm;
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }

        // Only show close button for non-welcome tabs
        if info.kind != "welcome" : IconButton {
            glyph: "×";
            size: 20px;
            y: (parent.height - self.height) / 2;
            clicked => { root.closed(); }
        }
    }
}

// --- TabBar ----------------------------------------------------------------
export component TabBar inherits Rectangle {
    in property <[TabInfo]> tabs;
    in property <string> active-id;
    callback tab-selected(string);
    callback tab-closed(string);
    callback new-tab();
    // 右键菜单回调
    callback close-tab(string);           // 关闭指定标签
    callback close-other-tabs(string);    // 关闭其他标签
    callback close-right-tabs(string);    // 关闭右侧标签
    callback close-all-tabs();            // 关闭所有标签

    // 右键菜单状态
    in-out property <bool> context-menu-open: false;
    in-out property <string> context-menu-tab-id: "";
    in-out property <length> context-menu-x: 0px;
    in-out property <length> context-menu-y: 0px;

    height: 36px;
    background: Theme.bg-panel-alt;

    HorizontalLayout {
        padding: 3px;
        spacing: 2px;

        for tab[i] in tabs : SingleTab {
            info: tab;
            active: tab.id == root.active-id;
            selected => { root.tab-selected(tab.id); }
            closed => { root.tab-closed(tab.id); }
            right-clicked => {
                root.context-menu-tab-id = tab.id;
                root.context-menu-open = true;
            }
        }

        IconButton {
            glyph: "+";
            size: 28px;
            y: (parent.height - self.height) / 2;
            clicked => { root.new-tab(); }
        }

        // Spacer
        Rectangle { horizontal-stretch: 1; }
    }

    // 右键菜单弹出层
    if context-menu-open : Rectangle {
        width: parent.width;
        height: parent.height;
        // 点击空白关闭菜单
        TouchArea {
            clicked => { root.context-menu-open = false; }
        }
    }

    if context-menu-open : Rectangle {
        x: root.context-menu-x;
        y: root.context-menu-y;
        width: 160px;
        height: menu-col.preferred-height;
        border-radius: Theme.radius-sm;
        border-width: 1px;
        border-color: Theme.border-subtle;
        background: Theme.bg-elevated;
        drop-shadow-blur: 8px;
        drop-shadow-color: #00000040;

        menu-col := VerticalLayout {
            padding: 4px;
            spacing: 2px;

            // 关闭当前标签
            Rectangle {
                height: 28px;
                border-radius: Theme.radius-sm;
                background: mi-close.has-hover ? Theme.bg-hover : transparent;
                mi-close := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.close-tab(root.context-menu-tab-id);
                        root.context-menu-open = false;
                    }
                }
                HorizontalLayout {
                    padding-left: 10px; spacing: 8px;
                    Text { text: "\u{E14C}"; font-family: "Material Icons"; color: Theme.text-secondary; font-size: 14px; vertical-alignment: center; }
                    Text { text: @tr("Close Tab"); color: Theme.text-primary; font-size: Theme.fs-sm; vertical-alignment: center; }
                }
            }

            // 关闭其他标签
            Rectangle {
                height: 28px;
                border-radius: Theme.radius-sm;
                background: mi-others.has-hover ? Theme.bg-hover : transparent;
                mi-others := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.close-other-tabs(root.context-menu-tab-id);
                        root.context-menu-open = false;
                    }
                }
                HorizontalLayout {
                    padding-left: 10px; spacing: 8px;
                    Text { text: "\u{E14C}"; font-family: "Material Icons"; color: Theme.text-secondary; font-size: 14px; vertical-alignment: center; }
                    Text { text: @tr("Close Other Tabs"); color: Theme.text-primary; font-size: Theme.fs-sm; vertical-alignment: center; }
                }
            }

            // 关闭右侧标签
            Rectangle {
                height: 28px;
                border-radius: Theme.radius-sm;
                background: mi-right.has-hover ? Theme.bg-hover : transparent;
                mi-right := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.close-right-tabs(root.context-menu-tab-id);
                        root.context-menu-open = false;
                    }
                }
                HorizontalLayout {
                    padding-left: 10px; spacing: 8px;
                    Text { text: "\u{E15C}"; font-family: "Material Icons"; color: Theme.text-secondary; font-size: 14px; vertical-alignment: center; }
                    Text { text: @tr("Close Tabs to the Right"); color: Theme.text-primary; font-size: Theme.fs-sm; vertical-alignment: center; }
                }
            }

            // 分割线
            Rectangle { height: 1px; background: Theme.border-subtle; }

            // 关闭所有标签
            Rectangle {
                height: 28px;
                border-radius: Theme.radius-sm;
                background: mi-all.has-hover ? Theme.danger.with-alpha(0.15) : transparent;
                mi-all := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.close-all-tabs();
                        root.context-menu-open = false;
                    }
                }
                HorizontalLayout {
                    padding-left: 10px; spacing: 8px;
                    Text { text: "\u{E14C}"; font-family: "Material Icons"; color: mi-all.has-hover ? Theme.danger : Theme.text-secondary; font-size: 14px; vertical-alignment: center; }
                    Text { text: @tr("Close All Tabs"); color: mi-all.has-hover ? Theme.danger : Theme.text-primary; font-size: Theme.fs-sm; vertical-alignment: center; }
                }
            }
        }
    }
}
